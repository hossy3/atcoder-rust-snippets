  // math:
  "combination": {
    "prefix": "_combination",
    "body": [
      "fn combination(n: usize, r: usize) -> usize {",
      "\tlet r = r.min(n - r);",
      "\t(1..=r).fold(1, |acc, x| acc * (n - x + 1) / x)",
      "}"
    ],
    "description": "組み合わせ数"
  },
  "combination_modint": {
    "prefix": "_combination_modint",
    "body": [
      "type Mint = ac_library::ModInt998244353;",
      "",
      "fn combination(n: usize, r: usize, fact: &[Mint], fact_inv: &[Mint]) -> Mint {",
      "\tfact[n] * fact_inv[r] * fact_inv[n - r]",
      "}",
      "",
      "fn build_fact(n: usize) -> Vec<Mint> {",
      "\tlet mut fact = vec![Mint::new(1); n + 1];",
      "\tfor i in 2..=n {",
      "\t\tfact[i] = fact[i - 1] * i;",
      "\t}",
      "\tfact",
      "}",
      "",
      "fn build_fact_inv(fact: &[Mint]) -> Vec<Mint> {",
      "\tlet n = fact.len() - 1;",
      "\tlet mut fact_inv = vec![Mint::new(1); n + 1];",
      "\tfor i in 0..=n {",
      "\t\tfact_inv[i] = fact[i].inv();",
      "\t}",
      "\tfact_inv",
      "}"
    ],
    "description": "組み合わせ数 ModInt"
  },
  "gcd": {
    "prefix": "_gcd",
    "body": [
      "fn gcd(a: usize, b: usize) -> usize {",
      "\tif b == 0 {",
      "\t\ta",
      "\t} else {",
      "\t\tgcd(b, a % b)",
      "\t}",
      "}"
    ],
    "description": "最大公約数 (Greatest Common Divisor)"
  },
  "lcm": {
    "prefix": "_lcm",
    "body": [
      "fn lcm(a: usize, b: usize) -> usize {",
      "\tfn gcd(a: usize, b: usize) -> usize {",
      "\t\tif b == 0 {",
      "\t\t\ta",
      "\t\t} else {",
      "\t\t\tgcd(b, a % b)",
      "\t\t}",
      "\t}",
      "",
      "\ta / gcd(a, b) * b",
      "}"
    ],
    "description": "最小公倍数 (Least Common Multiple)"
  },
  "build_primes": {
    "prefix": "_build_primes",
    "body": [
      "fn build_primes(n: usize) -> Vec<usize> {",
      "\tlet mut primes = vec![true; n + 1];",
      "\tprimes[0] = false;",
      "\tprimes[1] = false;",
      "\tfor i in 2..=n {",
      "\t\tif !primes[i] {",
      "\t\t\tcontinue;",
      "\t\t}",
      "\t\tlet m = n / i;",
      "\t\tfor j in 2..=m {",
      "\t\t\tprimes[i * j] = false;",
      "\t\t}",
      "\t}",
      "",
      "\tlet m = primes.iter().filter(|&&b| b).count();",
      "\tlet mut result = Vec::with_capacity(m);",
      "\tfor (i, &b) in primes.iter().enumerate() {",
      "\t\tif b {",
      "\t\t\tresult.push(i);",
      "\t\t}",
      "\t}",
      "\tresult",
      "}",
      ""
    ],
    "description": "素数列挙"
  },
  "prime_division": {
    "prefix": "_prime_division",
    "body": [
      "fn prime_division(mut n: usize) -> Vec<(usize, usize)> {",
      "\tlet mut result = vec![];",
      "\tlet mut k = 2;",
      "\twhile k * k <= n {",
      "\t\tlet mut count = 0;",
      "\t\twhile n % k == 0 {",
      "\t\t\tcount += 1;",
      "\t\t\tn /= k;",
      "\t\t}",
      "\t\tif count > 0 {",
      "\t\t\tresult.push((k, count));",
      "\t\t}",
      "\t\tk += if k == 2 { 1 } else { 2 };",
      "\t}",
      "\tif n > 1 {",
      "\t\tresult.push((n, 1));",
      "\t}",
      "\tresult",
      "}",
      ""
    ],
    "description": "素因数分解"
  },
  // graph:
  "build_ungraph": {
    "prefix": "_build_ungraph",
    "description": "無向グラフ組み立て (build undirected graph)",
    "body": [
      "fn build_ungraph(n: usize, uv: &[(usize, usize)]) -> Vec<Vec<usize>> {",
      "\tlet mut graph = vec![vec![]; n]; // node, edge",
      "\tfor &(u, v) in uv {",
      "\t\tgraph[u].push(v);",
      "\t\tgraph[v].push(u);",
      "\t}",
      "\tgraph",
      "}"
    ]
  },
  "build_ungraph_weight": {
    "prefix": "_build_ungraph_weight",
    "description": "無向グラフ組み立て 重み付き (build undirected graph with weight)",
    "body": [
      "fn build_ungraph_weight(n: usize, uvw: &[(usize, usize, usize)]) -> Vec<Vec<(usize, usize)>> {",
      "\tlet mut graph = vec![vec![]; n]; // node, (edge, weight)",
      "\tfor &(u, v, w) in uvw {",
      "\t\tgraph[u].push((v, w));",
      "\t\tgraph[v].push((u, w));",
      "\t}",
      "\tgraph",
      "}"
    ]
  },
  "shortest_graph_01bfs": {
    "prefix": "_shortest_graph_01bfs",
    "description": "重みなしグラフの s から e までの最短距離を 01-bfs で解く",
    "body": [
      "/// 重みなしグラフの s から e までの最短距離を 01-bfs で解く",
      "fn shortest_graph(graph: &[Vec<usize>], s: usize, e: usize) -> Option<usize> {",
      "\tlet mut set = HashSet::new();",
      "\tlet mut queue = VecDeque::new();",
      "\tqueue.push_back((0, s));",
      "",
      "\twhile let Some((step, i)) = queue.pop_front() {",
      "\t\tif i == e {",
      "\t\t\treturn Some(step);",
      "\t\t}",
      "\t\tfor &j in &graph[i] {",
      "\t\t\tif set.insert(j) {",
      "\t\t\t\tqueue.push_back((step + 1, j));",
      "\t\t\t}",
      "\t\t}",
      "\t}",
      "\tNone",
      "}"
    ]
  },
  "shortest_graph_dijkstra": {
    "prefix": "_shortest_graph_dijkstra",
    "description": "非負の重み付きグラフの s から e までの最短距離をダイクストラ法で解く",
    "body": [
      "/// 非負の重み付きグラフの s から e までの最短距離をダイクストラ法で解く",
      "fn shortest_graph(graph: &[Vec<(usize, usize)>], s: usize, e: usize) -> Option<usize> {",
      "\tlet mut set = HashSet::new();",
      "\tlet mut heap = BinaryHeap::new();",
      "\theap.push((Reverse(0), s));",
      "",
      "\twhile let Some((Reverse(step), i)) = heap.pop() {",
      "\t\tif i == e {",
      "\t\t\treturn Some(step);",
      "\t\t}",
      "\t\tif set.insert(i) {",
      "\t\t\tfor &(j, w) in &graph[i] {",
      "\t\t\t\tif !set.contains(&j) {",
      "\t\t\t\t\theap.push((Reverse(step + w), j));",
      "\t\t\t\t}",
      "\t\t\t}",
      "\t\t}",
      "\t}",
      "\tNone",
      "}"
    ]
  },
  "floyd_warshall": {
    "prefix": "_floyd_warshall",
    "description": "ワーシャルフロイド法 (floyd_warshall) で、重み付きグラフの全ペアの最短経路を解く",
    "body": [
      "/// ワーシャルフロイド法 (floyd_warshall) で、重み付きグラフの全ペアの最短経路を解く",
      "/// * `d`: 隣接行列 (d[u][v] が `u` から `v` への重み。 移動不可能は `usize::MAX` で示す)",
      "fn floyd_warshall(mut d: Vec<Vec<usize>>) -> Vec<Vec<usize>> {",
      "\tlet n = d.len();",
      "\tfor k in 0..n {",
      "\t\tfor i in 0..n {",
      "\t\t\tfor j in 0..n {",
      "\t\t\t\td[i][j] = d[i][j].min(d[i][k].saturating_add(d[k][j]));",
      "\t\t\t}",
      "\t\t}",
      "\t}",
      "\td",
      "}"
    ]
  },
  // algorithm:
  "knapsack": {
    "prefix": "_knapsack",
    "body": [
      "fn knapsack(n: usize, w_max: usize, wv: &[(usize, usize)]) -> usize {",
      "\tlet mut dp = Vec::with_capacity(n + 1);",
      "\tdp.push(vec![None; w_max + 1]);",
      "\tdp[0][0] = Some(0);",
      "\tfor (i, &(w, v)) in wv.iter().enumerate() {",
      "\t\tdp.push(dp.last().unwrap().clone());",
      "",
      "\t\tif w_max < w {",
      "\t\t\tcontinue;",
      "\t\t}",
      "\t\tfor j in 0..=(w_max - w) {",
      "\t\t\tif let Some(v0) = dp[i][j] {",
      "\t\t\t\tlet v1 = (v + v0).max(dp[i + 1][j + w].unwrap_or(0));",
      "\t\t\t\tdp[i + 1][j + w] = Some(v1);",
      "\t\t\t}",
      "\t\t}",
      "\t}",
      "",
      "\tlet result = dp[n].iter().filter(|&&x| x != None).max().unwrap().unwrap();",
      "\tresult",
      "}"
    ],
    "description": "Knapsack"
  },
  "solve_traveling_salesman": {
    "prefix": "_solve_traveling_salesman",
    "description": "巡回セールスマン問題 (Traveling Salesman Problem) を bit DP で解く",
    "body": [
      "/// 巡回セールスマン問題 (Traveling Salesman Problem) を bit DP で解く",
      "///",
      "/// state: state[bits][i] bits 到達済みの、現在位置 i でのコスト最小値。事前に usize::MAX で埋めておくこと",
      "/// dist: i から j に移動するときのコスト",
      "fn solve_traveling_salesman<F>(state: &mut Vec<Vec<usize>>, dist: F)",
      "where",
      "\tF: Fn(usize, usize) -> usize,",
      "{",
      "\tlet m = state[0].len();",
      "\tassert_eq!(1 << m, state.len());",
      "",
      "\tlet bit_test = |bits: usize, i: usize| bits & (1 << i) != 0;",
      "",
      "\tfor visited in 0..(1 << m) {",
      "\t\tfor i in 0..m {",
      "\t\t\tif state[visited][i] == usize::MAX {",
      "\t\t\t\tcontinue;",
      "\t\t\t}",
      "",
      "\t\t\tfor j in 0..m {",
      "\t\t\t\tif bit_test(visited, j) {",
      "\t\t\t\t\tcontinue;",
      "\t\t\t\t}",
      "\t\t\t\tlet x = state[visited][i] + dist(i, j);",
      "\t\t\t\tlet visited = visited | (1 << j);",
      "\t\t\t\tstate[visited][j] = state[visited][j].min(x);",
      "\t\t\t}",
      "\t\t}",
      "\t}",
      "}"
    ]
  },
  "lis": {
    "prefix": "_lis",
    "body": [
      "\t/// longest increasing subsequence",
      "\tfn lis(a: &[usize]) -> Vec<usize> {",
      "\t\tlet mut v = vec![0; a.len()];",
      "\t\tlet mut p = vec![];",
      "\t",
      "\t\tfor (i, &x) in a.iter().enumerate() {",
      "\t\t\tlet j = p.partition_point(|&y| y < x);",
      "\t\t\tif j == p.len() {",
      "\t\t\t\tp.push(x);",
      "\t\t\t} else if p[j] > x {",
      "\t\t\t\tp[j] = x;",
      "\t\t\t}",
      "\t\t\tv[i] = j + 1;",
      "\t\t}",
      "\t\tv",
      "\t}"
    ],
    "description": "Longest increasing subsequence"
  },
  // geometry:
  "partition_point_range": {
    "prefix": "_partition_point_range",
    "description": "partition_point() の Range 版",
    "body": [
      "/// !pred(x) となる最も小さな値を返す。 [..., true, false, ...] のように並ぶこと",
      "///",
      "/// ```",
      "/// assert_eq!(partition_point(0.., |i| i < 10), 10);",
      "/// assert_eq!(partition_point(0..1000, |_| false), 0);",
      "/// assert_eq!(partition_point(10..=1000, |_| true), 1001);",
      "/// ```",
      "fn partition_point<R, P>(range: R, pred: P) -> ${0:usize}",
      "where",
      "\tR: std::ops::RangeBounds<${0:usize}>,",
      "\tP: Fn(${0:usize}) -> bool,",
      "{",
      "\tlet mut r = match range.end_bound() {",
      "\t\tstd::ops::Bound::Included(r) => r + 1,",
      "\t\tstd::ops::Bound::Excluded(r) => *r,",
      "\t\tstd::ops::Bound::Unbounded => ${0:usize}::MAX,",
      "\t};",
      "\tlet mut l = match range.start_bound() {",
      "\t\tstd::ops::Bound::Included(l) => *l,",
      "\t\tstd::ops::Bound::Excluded(l) => l + 1,",
      "\t\tstd::ops::Bound::Unbounded => ${0:usize}::MIN,",
      "\t};",
      "\twhile l != r {",
      "\t\tlet mid = l + (r - l) / 2;",
      "\t\tif pred(mid) {",
      "\t\t\tl = mid + 1;",
      "\t\t} else {",
      "\t\t\tr = mid;",
      "\t\t}",
      "\t}",
      "\tl",
      "}"
    ]
  },
  "bit_test": {
    "prefix": "_bit_test",
    "body": [
      "trait BitTest {",
      "\tfn bit_test(&self, i: usize) -> bool;",
      "}",
      "",
      "impl BitTest for usize {",
      "\tfn bit_test(&self, i: usize) -> bool {",
      "\t\tself & (1 << i) != 0",
      "\t}",
      "}",
      ""
    ],
    "description": "Your description."
  },
  "bit_subset": {
    "prefix": "_bit_subset",
    "description": "ビット集合の部分集合を列挙するイテレータを返す",
    "body": [
      "struct BitSubset {",
      "\tstart: usize,",
      "\tnext: Option<usize>,",
      "}",
      "",
      "impl Iterator for BitSubset {",
      "\ttype Item = usize;",
      "",
      "\tfn next(&mut self) -> Option<Self::Item> {",
      "\t\tlet cur = self.next;",
      "\t\tif let Some(x) = self.next {",
      "\t\t\tself.next = if x > 0 {",
      "\t\t\t\tSome((x - 1) & self.start)",
      "\t\t\t} else {",
      "\t\t\t\tNone",
      "\t\t\t};",
      "\t\t}",
      "\t\tcur",
      "\t}",
      "}",
      "",
      "/// ビット集合の部分集合を列挙するイテレータを返す",
      "fn bit_subset(start: usize) -> BitSubset {",
      "\tBitSubset {",
      "\t\tstart,",
      "\t\tnext: Some(start),",
      "\t}",
      "}"
    ]
  },
  // データ構造
  "lazysegtree_maxadd": {
    "prefix": "_lazysegtree_maxadd",
    "description": "遅延セグメント木 区間加算 区間最大値",
    "body": [
      "/// 遅延セグメント木 区間加算 区間最大値",
      "/// # Examples",
      "/// ```",
      "/// let mut segtree: LazySegtree<MaxAdd> = vec![0usize; w].into();",
      "/// ```",
      "struct MaxAdd;",
      "impl MapMonoid for MaxAdd {",
      "\ttype M = Max<usize>;",
      "\ttype F = usize;",
      "",
      "\tfn identity_map() -> Self::F {",
      "\t\t0",
      "\t}",
      "\tfn mapping(&f: &Self::F, &x: &<Self::M as Monoid>::S) -> <Self::M as Monoid>::S {",
      "\t\tf + x",
      "\t}",
      "\tfn composition(&f: &Self::F, &g: &Self::F) -> Self::F {",
      "\t\tf + g",
      "\t}",
      "}"
    ]
  },
  "lazysegtree_addadd": {
    "prefix": "_lazysegtree_addadd",
    "description": "遅延セグメント木 区間加算 区間和",
    "body": [
      "/// 遅延セグメント木 区間加算 区間和 (区間の大きさも保持する)",
      "/// # Examples",
      "/// ```",
      "/// let mut segtree: LazySegtree<AddAdd> = (0..10).map(|&x| (1, x)).collect::<Vec<_>>().into();",
      "/// ```",
      "pub struct AddAddM;",
      "impl Monoid for AddAddM {",
      "\ttype S = (usize, usize); // (区間, 値)",
      "\tfn identity() -> Self::S {",
      "\t\t(1, 0)",
      "\t}",
      "\tfn binary_operation(a: &Self::S, b: &Self::S) -> Self::S {",
      "\t\t(a.0 + b.0, a.1 + b.1)",
      "\t}",
      "}",
      "",
      "struct AddAdd;",
      "impl MapMonoid for AddAdd {",
      "\ttype M = AddAddM;",
      "\ttype F = usize;",
      "",
      "\tfn identity_map() -> Self::F {",
      "\t\t0",
      "\t}",
      "\tfn mapping(&f: &Self::F, &x: &<Self::M as Monoid>::S) -> <Self::M as Monoid>::S {",
      "\t\t(x.0, x.1 + f * x.0)",
      "\t}",
      "\tfn composition(&f: &Self::F, &g: &Self::F) -> Self::F {",
      "\t\tf + g",
      "\t}",
      "}"
    ]
  },
  "inversion": {
    "prefix": "_inversion",
    "description": "転倒数 (inversion) を求める",
    "body": [
      "/// 転倒数 (inversion) を求める",
      "/// * `a` - 0 開始の配列。 例: `[3, 1, 4, 2, 0]`",
      "fn inversion(a: &[usize]) -> usize {",
      "\tlet n = a.len();",
      "\tlet mut tree = FenwickTree::new(n, 0usize);",
      "\tlet mut count = 0usize;",
      "\tfor (_, &xr) in a.iter().enumerate() {",
      "\t\ttree.add(xr, 1);",
      "\t\tcount += tree.sum((xr + 1)..);",
      "\t}",
      "",
      "\tcount",
      "}"
    ]
  },
  // misc
  "count_grid_by_imos_2d": {
    "prefix": "_count_grid_by_imos_2d",
    "description": "(r1 - r0) * (c1 - c0) の大きさの長方形を重ねた時に、各グリッドに何枚あるかを imos 2D で求める",
    "body": [
      "/// (r1 - r0) * (c1 - c0) の大きさの長方形を重ねた時に、各グリッドに何枚あるかを imos 2D で求める",
      "fn count_grid_by_imos_2d(n: usize, rc: &[(usize, usize, usize, usize)]) -> Vec<Vec<usize>> {",
      "\tlet mut imos = vec![vec![0isize; n + 1]; n + 1];",
      "\tfor &(r0, c0, r1, c1) in rc {",
      "\t\timos[r0][c0] += 1;",
      "\t\timos[r1 + 1][c0] -= 1;",
      "\t\timos[r0][c1 + 1] -= 1;",
      "\t\timos[r1 + 1][c1 + 1] += 1;",
      "\t}",
      "",
      "\tlet mut counts = vec![vec![0isize; n + 1]; n + 1];",
      "\tfor x in 0..n {",
      "\t\tfor y in 0..n {",
      "\t\t\tcounts[x + 1][y + 1] = counts[x][y + 1] + counts[x + 1][y] - counts[x][y] + imos[x][y];",
      "\t\t}",
      "\t}",
      "",
      "\tlet mut results = vec![vec![0; n]; n];",
      "\tfor x in 0..n {",
      "\t\tfor y in 0..n {",
      "\t\t\tresults[x][y] = counts[x + 1][y + 1] as usize;",
      "\t\t}",
      "\t}",
      "\tresults",
      "}"
    ]
  },
  "meet_in_the_middle": {
    "prefix": "_meet_in_the_middle",
    "description": "半分全列挙",
    "body": [
      "/// 半分全列挙: a から複数選んで和を s にする組み合わせ数の例",
      "fn meet_in_the_middle(s: usize, a: &[usize]) -> usize {",
      "\tlet n = a.len();",
      "\tassert!(n <= 40);",
      "",
      "\tlet mut m0 = HashMap::new();",
      "\tm0.insert(0usize, 1usize);",
      "\tfor &x in &a[..(n / 2)] {",
      "\t\tlet mut m = m0.clone();",
      "\t\tfor (&k, &v) in &m0 {",
      "\t\t\t*m.entry(k + x).or_insert(0) += v;",
      "\t\t}",
      "\t\tm0 = m;",
      "\t}",
      "",
      "\tlet mut m1 = HashMap::new();",
      "\tm1.insert(0usize, 1usize);",
      "\tfor &x in &a[(n / 2)..] {",
      "\t\tlet mut m = m1.clone();",
      "\t\tfor (&k, &v) in &m1 {",
      "\t\t\t*m.entry(k + x).or_insert(0) += v;",
      "\t\t}",
      "\t\tm1 = m;",
      "\t}",
      "",
      "\tlet mut result = 0usize;",
      "\tfor (&k0, &v0) in &m0 {",
      "\t\tif k0 <= s {",
      "\t\t\tif let Some(&v1) = m1.get(&(s - k0)) {",
      "\t\t\t\tresult += v0 * v1;",
      "\t\t\t}",
      "\t\t}",
      "\t}",
      "",
      "\tresult",
      "}"
    ]
  }
}
